# ------------------------------------------------------------------
# TP4 - Cles API pour les fournisseurs LLM.
# Copiez ce fichier en .env et renseignez les cles dont vous disposez :
#     cp .env.example .env
# .env est ignore par git : ne versionnez JAMAIS une cle API.
# Vous n'avez PAS besoin des 4 : UNE seule suffit pour faire le TP.
# ------------------------------------------------------------------

# OpenAI (ChatGPT) - https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Google Gemini - https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Anthropic (Claude) - https://console.anthropic.com/settings/keys
# Par defaut claude-opus-4-8 ; pour un cout moindre : claude-haiku-4-5.
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-opus-4-8

# Modele LOCAL via Ollama (https://ollama.com) ou tout serveur compatible OpenAI.
# Ex : installez Ollama, puis `ollama pull llama3.1` et laissez l'URL par defaut.
# Aucune cle n'est requise pour Ollama (le SDK exige juste une valeur non vide).
LOCAL_BASE_URL=http://localhost:11434/v1
LOCAL_API_KEY=ollama
LOCAL_MODEL=llama3.1
